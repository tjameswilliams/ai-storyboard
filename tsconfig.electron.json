{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "outDir": "electron/dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "electron/**/*.ts",
    "server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "client",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts"
  ]
}
