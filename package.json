{
  "name": "ai-storyboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/dist/main.mjs",
  "scripts": {
    "dev": "bash scripts/check-port.sh && bun run dev:server & bun run dev:client",
    "dev:server": "bun run --hot server/index.ts",
    "dev:client": "cd client && bun run dev",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "test": "bun test",
    "mcp": "bun run server/lib/mcp/server.ts",
    "sync-table": "bun run scripts/sync-table.ts",
    "build:client": "cd client && npx vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "dev:electron": "npm run build:client && npm run build:electron && electron electron/dist/main.mjs",
    "dev:electron:b": "ASB_DATA_DIR=\"$HOME/.asb-b\" npm run dev:electron",
    "sync-workflows:a-to-b": "bun run scripts/sync-table.ts --table workflows --from \"$HOME/Library/Application Support/AI Storyboard\" --to \"$HOME/.asb-b\"",
    "sync-settings:a-to-b": "bun run scripts/sync-table.ts --table settings --from \"$HOME/Library/Application Support/AI Storyboard\" --to \"$HOME/.asb-b\"",
    "package": "npm run build:client && npm run build:electron && electron-builder",
    "package:mac": "npm run package -- --mac",
    "package:win": "npm run package -- --win",
    "package:linux": "npm run package -- --linux"
  },
  "workspaces": ["client"],
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "jsdom": "24.1.3",
    "jszip": "^3.10.1",
    "nanoid": "^5.1.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.0",
    "@types/jsdom": "21.1.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "drizzle-kit": "^0.30.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1"
  }
}
